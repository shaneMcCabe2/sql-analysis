# Copy this file to .streamlit/secrets.toml and fill in your service-account values.
# secrets.toml is gitignored — never commit the real file.
#
# To find these values: open secure/<your-key>.json and paste each field below.

[gcp_service_account]
type                        = "service_account"
project_id                  = "sql-analysis-500017"
private_key_id              = "REPLACE_ME"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----\n"
client_email                = "REPLACE_ME@sql-analysis-500017.iam.gserviceaccount.com"
client_id                   = "REPLACE_ME"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "REPLACE_ME"
